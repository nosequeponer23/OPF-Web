---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { createClient } from "@supabase/supabase-js";
import Tarjeta from "../components/Tarjeta.astro";
import Oro from "../assets/medallas/OPFOro.png";
import Plata from "../assets/medallas/OPFPlata.png";
import Bronce from "../assets/medallas/OPFBronce.png";

// Ruta de las calis
//import RawCal from "../data/resultados.json";

// CAMBIAR A TRUE PARA PUBLICAR RESULTADOS
const resultadosPublicados = false;

interface Participante {
  nombre: string;
  escuela: string;
  cal: number;
}

let podiog: any[] = [];
let GRes: any[] = [];
const Medallas = [Oro, Plata, Bronce];
const NPodio = ["1er Lugar", "2do Lugar", "3er Lugar"];

const supabaseUrl = import.meta.env.SUPABASE_URL;
const supabaseKey = import.meta.env.SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

if (resultadosPublicados) {
  const { data: RawCal, error } = await supabase
    .from("OPF Resultados")
    .select("nombre, escuela, cal");

  if (error) {
    console.error("Error al obtener datos de Supabase:", error);
  }

  if (RawCal) {
    const ParticipantesOrdenados = [...RawCal].sort(
      (a: Participante, b: Participante) => b.cal - a.cal,
    );

    podiog = ParticipantesOrdenados.slice(0, 3).map(
      (participante: Participante, index: number) => ({
        puesto: NPodio[index],
        nombre: participante.nombre,
        escuela: participante.escuela,
        medalla: Medallas[index],
      }),
    );

    GRes = ParticipantesOrdenados.slice(3).map((participante, index) => ({
      posicion: index + 4,
      nombre: participante.nombre,
      escuela: participante.escuela,
    }));
  }
}
---

<Layout>
  <main class="contenedor-resultados">
    <h1 class="titulo">Resultados de la Olimpiada</h1>

    {
      resultadosPublicados ? (
        <>
          <p class="subtitulo">
            Conoce a los perfiles destacados de esta edición.
          </p>

          <section class="podio">
            {podiog.map((participante) => (
              <Tarjeta hover={true}>
                <div class="medalla">
                  <Image
                    src={participante.medalla}
                    alt={`Medalla de ${participante.puesto}`}
                  />
                </div>
                <h2>{participante.nombre}</h2>
                <hr />
                <p class="escuela">{participante.escuela}</p>
                <p class="puesto-texto">{participante.puesto}</p>
              </Tarjeta>
            ))}
          </section>

          <section class="seccion-tabla">
            <h2 class="subtitulo-tabla">Tabla General de Posiciones</h2>

            <div class="tabla-responsiva">
              <table class="tabla-resultados">
                <thead>
                  <tr>
                    <th>Posición</th>
                    <th>Nombre</th>
                    <th>Escuela</th>
                  </tr>
                </thead>
                <tbody>
                  {GRes.map((alumno) => (
                    <tr>
                      <td>
                        <strong>{alumno.posicion}</strong>
                      </td>
                      <td>{alumno.nombre}</td>
                      <td>{alumno.escuela}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </>
      ) : (
        /* --- VISTA DE ESPERA (Si es FALSE) --- */
        <Tarjeta class="proximamente">
          <div class="icono-espera">⏳</div>
          <h2 class="titulo-espera">¡Próximamente!</h2>
          <p class="texto-espera">
            Estamos afinando los últimos detalles y calculando los puntajes.
            Vuelve pronto para conocer a los ganadores de esta edición.
          </p>
        </Tarjeta>
      )
    }
  </main>
</Layout>

<style>
  .contenedor-resultados {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem;
    text-align: center;
  }

  .titulo {
    font-size: 2.8rem;
    color: var(--azulUaslp);
    margin-bottom: 0.5rem;
  }

  .subtitulo {
    font-size: 1.2rem;
  }

  .podio {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-top: 3rem;
    margin-bottom: 4rem;
  }

  .escuela {
    color: var(--verde);
    font-weight: bold;
    margin-top: 0.5rem;
  }

  .puesto-texto {
    color: var(--dorado);
    font-weight: 800;
    text-transform: uppercase;
    font-size: 0.9rem;
    margin-top: 0.5rem;
  }

  .medalla {
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  .medalla img {
    width: 80px;
    height: auto;
  }

  .seccion-tabla {
    text-align: left;
    margin-top: 4rem;
  }

  .subtitulo-tabla {
    font-size: 1.8rem;
    color: var(--naranja);
    margin-bottom: 2rem;
    text-align: center;
  }

  .tabla-responsiva {
    overflow-x: auto;
    border-radius: 12px;
    border: 1px solid var(--gris);
    background: #fff;
  }

  .tabla-resultados {
    width: 100%;
    border-collapse: collapse;
  }

  .tabla-resultados th,
  .tabla-resultados td {
    padding: 1.2rem;
    border-bottom: 1px solid var(--gris);
  }

  .tabla-resultados th {
    background-color: var(--naranja);
    color: #fff;
    text-align: left;
  }

  .tabla-resultados tbody tr:hover {
    background-color: var(--crema);
  }

  .proximamente {
    margin-top: 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 5rem 2rem;
  }

  .icono-espera {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  .titulo-espera {
    color: var(--negro);
    font-size: 2.2rem;
    margin-bottom: 1rem;
  }

  .texto-espera {
    font-size: 1.2rem;
    line-height: 1.6;
  }
</style>
